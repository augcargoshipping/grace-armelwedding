# Primary: Upstash Redis (recommended — add from Vercel Marketplace → Redis)
# Vercel adds UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN (or KV_* legacy names)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Fallback: Vercel Blob (grace-armel-wedding-invite-blob)
# Copy BLOB_READ_WRITE_TOKEN from the Blob store → .env tab → Production
BLOB_READ_WRITE_TOKEN=

# Optional: legacy Supabase (merged in admin if project is still reachable)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-sb-secret-key-here

# Admin portal at /admin/rsvp (triple-tap footer)
RSVP_ADMIN_PASSWORD=your-admin-password
# Optional: separate signing secret (defaults to RSVP_ADMIN_PASSWORD)
# RSVP_ADMIN_SECRET=
