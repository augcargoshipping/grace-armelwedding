# Vercel Blob (required for new RSVP submissions)
# On Vercel: connecting the store adds BLOB_STORE_ID (+ OIDC). Locally: run `vercel env pull`.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx
# BLOB_STORE_ID is added automatically when the Blob store is connected to the project.

# Optional: legacy Supabase (merged in admin if project is still reachable)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-sb-secret-key-here

# Admin portal at /admin/rsvp (triple-tap footer)
RSVP_ADMIN_PASSWORD=your-admin-password
# Optional: separate signing secret (defaults to RSVP_ADMIN_PASSWORD)
# RSVP_ADMIN_SECRET=
